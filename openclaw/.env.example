# OpenClaw Configuration
# Копировать в .env и заполнить значения

# Директории на хосте (создаются автоматически install.sh)
# По умолчанию: ~/.openclaw и ~/.openclaw/workspace
# OPENCLAW_CONFIG_DIR=/home/gigglin/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/gigglin/.openclaw/workspace

# Gateway Token (генерируется при onboard, НЕ МЕНЯТЬ ВРУЧНУЮ)
# Proxy Configuration (optional)
# OPENCLAW_PROXY_URL=http://user:pass@ip:port

# Obsidian Vault (синхронизируется через Syncthing)
# OBSIDIAN_VAULT_DIR=/home/gigglin/obsidian-vault
