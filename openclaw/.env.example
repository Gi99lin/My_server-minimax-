# ============================================================
# OpenClaw — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- Infrastructure ---
OPENCLAW_CONFIG_DIR=/home/gigglin/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/gigglin/.openclaw/workspace
OBSIDIAN_VAULT_DIR=/home/gigglin/obsidian-vault

# --- Gateway ---
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# --- Proxy (for geo-restricted API access) ---
OPENCLAW_PROXY_URL=http://user:pass@proxy-host:port

# --- API Keys ---
TAVILY_API_KEY=tvly-dev-xxxxx
TRADINGVIEW_RAPIDAPI_KEY=your_rapidapi_key_here
BRAVE_API_KEY=your_brave_api_key_here
OPENROUTER_API_KEY=sk-or-v1-xxxxx
ZAI_API_KEY=your_zai_api_key_here
OMNIROUTE_API_KEY=sk-xxxxx

# --- Telegram Bots ---
TELEGRAM_BOT_TOKEN_MAIN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_BOT_TOKEN_FINANALYST=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
