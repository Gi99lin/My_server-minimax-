# ═══════════════════════════════════════════════════
#   OmniRoute — Environment Variables
#   Скопируй в .env и заполни секреты
# ═══════════════════════════════════════════════════

# ─── REQUIRED SECRETS ────────────────────────────
# Сгенерируй: openssl rand -base64 48
JWT_SECRET=
# Сгенерируй: openssl rand -hex 32
API_KEY_SECRET=

# Первый пароль администратора — смени до первого запуска!
INITIAL_PASSWORD=CHANGEME

# ─── STORAGE ─────────────────────────────────────
DATA_DIR=/app/data
STORAGE_DRIVER=sqlite
# Сгенерируй: openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=
STORAGE_ENCRYPTION_KEY_VERSION=v1
LOG_RETENTION_DAYS=90
SQLITE_MAX_SIZE_MB=2048
SQLITE_CLEAN_LEGACY_FILES=true

# ─── PORTS ───────────────────────────────────────
PORT=20128
# API_PORT=20129
# API_HOST=0.0.0.0
# DASHBOARD_PORT=20128
# Публикуемые порты на хосте (переопределяются в docker-compose.yml):
OMNIROUTE_DASHBOARD_PORT=20130
OMNIROUTE_API_PORT=20131

# ─── PROXY (outbound — исходящий прокси) ─────────
# Раскомментируй и выбери формат нужного прокси:
# HTTP/HTTPS прокси:
# OMNIROUTE_PROXY_URL=http://user:pass@proxy-host:port
# SOCKS5 прокси:
# OMNIROUTE_PROXY_URL=socks5://user:pass@proxy-host:port
ENABLE_SOCKS5_PROXY=true
NEXT_PUBLIC_ENABLE_SOCKS5_PROXY=true
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=
# NO_PROXY=localhost,127.0.0.1

# ─── URLS (для корректной работы за реверс-прокси) ─
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128
# Для публичного доступа через nginx-proxy-manager замени:
# BASE_URL=https://omniroute.your-domain.com
# NEXT_PUBLIC_BASE_URL=https://omniroute.your-domain.com

# ─── CLOUD SYNC (опционально) ────────────────────
CLOUD_URL=
NEXT_PUBLIC_CLOUD_URL=

# ─── MISC ─────────────────────────────────────────
NODE_ENV=production
INSTANCE_NAME=omniroute
MACHINE_ID_SALT=endpoint-proxy-salt
ENABLE_REQUEST_LOGS=false
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false
LOG_TO_FILE=true

# ─── TLS FINGERPRINT SPOOFING (опционально) ───────
# Маскирует JA3/JA4 fingerprint под Chrome
# ENABLE_TLS_FINGERPRINT=true

# ─── GOOGLE OAUTH (нужно для Antigravity / Gemini CLI на сервере) ─
# На remote-сервере стандартные credentials не работают — нужно своё OAuth приложение.
# Инструкция: https://github.com/diegosouzapw/OmniRoute#readme
# ANTIGRAVITY_OAUTH_CLIENT_ID=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
# GEMINI_CLI_OAUTH_CLIENT_ID=
# GEMINI_CLI_OAUTH_CLIENT_SECRET=

# ─── USER-AGENT OVERRIDES (опционально) ───────────
CLAUDE_USER_AGENT=claude-cli/1.0.83 (external, cli)
CODEX_USER_AGENT=codex-cli/0.92.0 (Windows 10.0.26100; x64)
GITHUB_USER_AGENT=GitHubCopilotChat/0.26.7
ANTIGRAVITY_USER_AGENT=antigravity/1.104.0 darwin/arm64
GEMINI_CLI_USER_AGENT=google-api-nodejs-client/9.15.1

# ─── API KEY PROVIDERS (опционально) ──────────────
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
