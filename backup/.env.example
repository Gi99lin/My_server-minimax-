# ============================================================
# Backblaze B2 credentials
# Создать bucket и Application Key в https://www.backblaze.com/
# ============================================================
B2_ACCOUNT_ID=your_keyID_here
B2_ACCOUNT_KEY=your_applicationKey_here
B2_BUCKET_NAME=my-server-backup

# ============================================================
# Restic encryption password
# ВАЖНО: сохрани этот пароль отдельно (в менеджере паролей)!
# Без него расшифровать бэкап невозможно.
# ============================================================
RESTIC_PASSWORD=generate_a_strong_password_here

# ============================================================
# Database passwords for mysqldump
# ============================================================
NPM_DB_ROOT_PASSWORD=npm_root_password

# ============================================================
# Notification (optional) — Telegram bot для уведомлений
# Оставь пустым если не нужно
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
