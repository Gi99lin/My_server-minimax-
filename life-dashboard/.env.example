# ---- Garmin Connect ----
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# ---- Paths ----
# Obsidian vault on the host (read by API for daily note sync)
VAULT_PATH=/mnt/data/obsidian

# Git repos directory (read by collector for commit tracking)
GIT_REPOS_PATH=/mnt/data/repos

# ---- Weather ----
# Moscow coordinates (default)
# WEATHER_LAT=55.7558
# WEATHER_LON=37.6173
